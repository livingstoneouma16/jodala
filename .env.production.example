# Production environment for Jodala Microfinance.
#
# Copy this to .env.production, fill in real values, and NEVER commit the
# filled-in copy (it's already covered by .gitignore/.dockerignore).
#
# Generate SECRET_KEY / JWT_SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Use a DIFFERENT value for each -- don't reuse one for both.

APP_ENV=production

SECRET_KEY=
JWT_SECRET_KEY=

# Where the SQLite file lives. In Docker this is the mounted volume path
# from docker-compose.yml (/data/sacco.db) -- don't change it unless you
# also change the volume mount. Outside Docker, point this at a path on
# a disk that's actually backed up.
DB_PATH=/data/sacco.db

# Auth cookie is forced to Secure automatically when APP_ENV=production
# (see app/__init__.py) -- only set this if you need to override that.
# COOKIE_SECURE=true

# Required for correct rate limiting once you run more than one gunicorn
# worker (WEB_CONCURRENCY > 1) -- without a shared store, each worker
# tracks login attempts separately, so the real limit is N times weaker
# than configured. docker-compose.yml already points this at the bundled
# Redis service; only change it if you're not using that compose file.
RATELIMIT_STORAGE_URI=redis://redis:6379/0

# Leave empty unless a separately-hosted frontend needs to call this API
# cross-origin (the server-rendered pages in this app don't). Never set to "*".
CORS_ALLOWED_ORIGINS=

WEB_CONCURRENCY=2

# --- Overdue-loan reminder scheduler -------------------------------------
# Runs daily inside the web process (core/scheduler.py) -- no external cron
# needed. Set to false to disable and drive send_overdue_reminders.py from
# your own external scheduler instead.
ENABLE_OVERDUE_SCHEDULER=true
OVERDUE_REMINDER_HOUR=8
OVERDUE_REMINDER_MINUTE=0
SCHEDULER_TIMEZONE=Africa/Nairobi

# --- Gmail (email notifications) ------------------------------------------
# Can also be set from Settings > Notifications in-app instead (takes
# precedence over these). Use a Gmail App Password, not your normal
# password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=jodalamicrofinance@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_SENDER_NAME=

# --- M-Pesa -----------------------------------------------------------------
# Can also be set from Settings > M-Pesa in-app (recommended -- takes
# precedence). Set MPESA_ENVIRONMENT=production with real Daraja production
# credentials once you're ready to accept/send real money; sandbox works
# with no config for STK Push, but B2C (disbursement) needs its own
# Initiator Name/Password/Certificate configured either way -- see the
# in-app Settings > M-Pesa page for details.
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
