# Copy this file to .env and fill in real values. .env is loaded automatically
# (python-dotenv) by app/__init__.py.

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# PostgreSQL connection string. Falls back to assembling one from PGHOST/
# PGUSER/PGPASSWORD/PGDATABASE (see core/database.py:resolve_db_url) if
# unset, and finally to postgresql://postgres@localhost:5432/jodala --
# create that DB locally with `createdb jodala` before first run.
DATABASE_URL=postgresql://postgres@localhost:5432/jodala

# --- CORS -----------------------------------------------------------------
# Comma-separated list of origins allowed to make cross-origin requests to
# this API (e.g. a separately-hosted frontend). Leave unset/empty to allow
# NO cross-origin access -- the server-rendered pages in this app call the
# API same-origin and don't need this. Do NOT set this to "*".
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# --- M-Pesa (STK Push / Lipa Na M-Pesa Online) --------------------------
# Credentials can also be set in-app under Settings > M-Pesa (recommended --
# takes precedence over these). Leave unset to use Safaricom's public
# sandbox shortcode/passkey defaults (still need your own Consumer
# Key/Secret from developer.safaricom.co.ke -- those can't have a shared
# default). Set MPESA_ENVIRONMENT=production + real credentials to go live.
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# --- Cookies ----------------------------------------------------------------
# Set to "true" once this app is served over HTTPS in production so the auth
# cookie is only ever sent over an encrypted connection. Keep "false" for
# plain-HTTP local development, otherwise the browser will silently refuse
# to store the cookie and login won't work.
COOKIE_SECURE=false

# --- Overdue-loan reminder scheduler -------------------------------------
# Runs daily inside the web process (core/scheduler.py) -- no external cron
# needed. Set to false to disable and drive send_overdue_reminders.py from
# your own external scheduler instead.
ENABLE_OVERDUE_SCHEDULER=true
OVERDUE_REMINDER_HOUR=8
OVERDUE_REMINDER_MINUTE=0
SCHEDULER_TIMEZONE=UTC

# --- Gmail email notifications ------------------------------------------
# These are only used as a FALLBACK if the same settings haven't been
# entered in-app under Settings > Notifications (which takes priority).
# Either place works; you don't need both.
#
# 1. Turn on 2-Step Verification on the Gmail account:
#    https://myaccount.google.com/security
# 2. Generate an App Password (NOT your normal Gmail password):
#    https://myaccount.google.com/apppasswords
#    -> choose "Mail" as the app, copy the 16-character password it gives you.
# 3. Paste that below (spaces are fine, they're stripped automatically).
GMAIL_ADDRESS=youraccount@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_SENDER_NAME=Jodala Microfinance

# --- SMS notifications (Africa's Talking) --------------------------------
# Texts members/clients directly for loan approvals, disbursements,
# repayments, savings deposits/withdrawals, overdue reminders, and new
# registrations. These are only used as a FALLBACK if the same settings
# haven't been entered in-app under Settings > Notifications (which takes
# priority). SMS sending stays off (SMS_NOTIFICATIONS_ENABLED=false) until
# explicitly turned on -- either here or in Settings.
#
# 1. Create an account at https://africastalking.com (free sandbox works
#    for testing, but only delivers to real phones on a live app).
# 2. Copy the Username and API Key from the dashboard.
# 3. Optionally set a registered Sender ID / short code -- leave blank to
#    send from Africa's Talking's shared alphanumeric ID.
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
SMS_NOTIFICATIONS_ENABLED=false
